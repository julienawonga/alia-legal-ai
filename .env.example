# ──────────────────────────────────────────────────
# Gemini API — Used for text-to-text translation ONLY (cost-optimized)
# ──────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_TEXT_MODEL=gemini-2.5-flash

# ──────────────────────────────────────────────────
# Legal LLM — OpenAI-compatible endpoint for law inference
# ──────────────────────────────────────────────────
LLM_BASE_URL=https://your-llm-endpoint.com/v1
LLM_API_KEY=your-llm-api-key
LLM_MODEL_ID=your-model-id

# ──────────────────────────────────────────────────
# STT/TTS API — External Bambara speech service (cost-optimized, avoids Gemini audio billing)
# ──────────────────────────────────────────────────
SPEECH_API_BASE_URL=https://your-speech-api.com
SPEECH_API_KEY=your-speech-api-key
